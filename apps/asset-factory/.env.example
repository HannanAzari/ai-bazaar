# Nestudio Asset Factory — environment variables.

# ── Access gate ──────────────────────────────────────────────────────────────
# Optional. If set, the whole app is gated behind this password (cookie-checked in
# middleware.ts + the API routes). If left blank/unset, the app runs OPEN (local).
ASSET_FACTORY_PASSWORD=

# ── Shared backend (V2) ──────────────────────────────────────────────────────
# Leave ALL blank to run in local (localStorage) mode. Set all three to enable the
# shared Supabase backend so reviews persist across devices.
#
# NEXT_PUBLIC_* are the client-visible mode signal. The SERVICE ROLE key is
# server-only (never NEXT_PUBLIC) — all DB/storage access happens in the
# password-gated API routes, so the anon key never touches the tables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI generation (V3) ───────────────────────────────────────────────────────
# Generation is OFF by default. Dry-run (zero cost) always works; REAL generation
# requires BOTH the flag set to "true" AND a Replicate token. The token is
# server-only and never sent to the browser.
ASSET_GENERATION_ENABLED=false
REPLICATE_API_TOKEN=
# Optional overrides (defaults shown):
# GENERATION_MODEL=black-forest-labs/flux-schnell
# GENERATION_COST_PER_IMAGE=0.003
# ASSET_GENERATION_MAX_BATCH=5
# ASSET_GENERATION_DAILY_LIMIT=50
# GENERATION_TIMEOUT_MS=60000
# GENERATION_RETRY_LIMIT=1
