NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend mode (lib/runtime-mode.ts): blank URL + anon key = DEMO (localStorage).
# Setting BOTH switches the app to production mode. See docs/supabase-cutover.md.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_DRIVER=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Feature flags (see lib/flags.ts). Blank uses the built-in default.
# Sprint 1 features default on; later-sprint features default off.
NEXT_PUBLIC_ENABLE_CREATOR_PROFILES=
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=
NEXT_PUBLIC_ENABLE_GUESTBOOKS=
NEXT_PUBLIC_ENABLE_COLLECTIONS=
NEXT_PUBLIC_ENABLE_ACTIVITY_FEED=
NEXT_PUBLIC_ENABLE_ASSET_CATALOG=
NEXT_PUBLIC_ENABLE_ROOM_ENGINE=
